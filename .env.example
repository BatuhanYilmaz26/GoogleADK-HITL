# ── Google Sheets ────────────────────────────────────────────────────
# The long ID from the Sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SPREADSHEET_ID=your-spreadsheet-id-here

# Name of the tab/sheet inside the spreadsheet (default: Sheet1)
SHEET_NAME=Sheet1

# ── Optional API-Key Fallback ────────────────────────────────────────
# Only used when REQUIRE_SERVICE_ACCOUNT=false and no service account file exists.
# Writes should use a service account in production.
GOOGLE_API_KEY=
SHEETS_API_KEY=

# ── Service Account ─────────────────────────────────────────────────
# Path to the Google Cloud service account JSON file.
SERVICE_ACCOUNT_PATH=service_account.json
REQUIRE_SERVICE_ACCOUNT=true

# ── Webhook Security (optional) ──────────────────────────────────────
# Shared secret between Apps Script and FastAPI (leave blank to disable)
WEBHOOK_SECRET=

# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=https://your-ada-domain.example
ALLOW_CREDENTIALS=false

# ── Persistent Session Store ─────────────────────────────────────────
SESSION_DB_PATH=hitl_sessions.db
SESSION_RETENTION_HOURS=168
SESSION_CLEANUP_INTERVAL_SECONDS=1800
SESSION_LIST_MAX_LIMIT=500

# ── Review Workers ───────────────────────────────────────────────────
REVIEW_WORKER_COUNT=4
REVIEW_WORKER_IDLE_SLEEP_SECONDS=0.5
REVIEW_JOB_VISIBILITY_TIMEOUT_SECONDS=300

# ── Debugging ────────────────────────────────────────────────────────
# Set to any value (e.g. DEBUG=1) to enable DEBUG-level logging
# DEBUG=1
